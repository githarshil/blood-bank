# Backend environment variables for local development
PORT=3001
NODE_ENV=development

# MySQL Local Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bloodbankdb

# Set to true only if your local database requires SSL
DB_SSL=false

# Allowed frontend URL (Vite dev server default)
CORS_ORIGIN=http://localhost:5173
