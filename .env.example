# Backend environment variables (copy to .env locally, set in Render dashboard for production)

PORT=3001
NODE_ENV=development

# MySQL — use your cloud provider credentials (Aiven, Railway, etc.)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=bloodbankdb

# Set to "true" for most cloud MySQL hosts (Aiven, PlanetScale, etc.)
DB_SSL=false

# Comma-separated allowed frontend URLs (no trailing slash)
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app (optional — *.vercel.app allowed automatically)
CORS_ORIGIN=http://localhost:3000

# Vercel sets VERCEL=1 and VERCEL_URL automatically — do not set manually

# Railway Backend Configuration (optional reference for production backend URL)
# RAILWAY_BACKEND_URL=https://blood-bank-production-eef6.up.railway.app
